# Application
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3000
WEB_URL=http://localhost:3000

# Database (PostgreSQL 15 via Docker — port 5433 maps to 5432)
DATABASE_URL="postgresql://synkaro_user:synkaro2026@localhost:5433/synkaro_db"

# Redis 7
REDIS_URL="redis://localhost:6379"

# JWT (generate with: [Convert]::ToBase64String((1..48 | %{ Get-Random -Maximum 256 }))
JWT_SECRET=replace-with-a-very-long-random-string
JWT_REFRESH_SECRET=replace-with-another-long-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Gmail SMTP (for OTP emails — use your Gmail App Password)
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-password
MAIL_FROM="Synkaro <no-reply@synkaro.dev>"

# Google OAuth 2.0
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# LiveKit (matches docker-compose LIVEKIT_KEYS)
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devkeysecret
LIVEKIT_URL=ws://localhost:7880

# Uploads
UPLOAD_DIR=./uploads

# Cookies (dev = no secure, no domain)
COOKIE_DOMAIN=
COOKIE_SECURE=false
