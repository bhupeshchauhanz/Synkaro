# Copy this file to .env.local when you want to access Synkaro from another
# device on your local network (phone, tablet, another laptop).
#
# Replace 10.184.70.68 with your machine's LAN IP if it changes.
#   Find it with: ipconfig (look for IPv4 Address)
#
# Then run:
#   web/    : npx next dev -H 0.0.0.0
#   backend : npm run start:dev   (the Nest app already binds 0.0.0.0)
#
# On the other device, open http://10.184.70.68:3000

NEXT_PUBLIC_API_URL=http://10.184.70.68:3001/api
NEXT_PUBLIC_WS_URL=http://10.184.70.68:3001
NEXT_PUBLIC_SITE_URL=http://10.184.70.68:3000
NEXT_PUBLIC_GOOGLE_CLIENT_ID=219515319902-gq18v8g8b944khqq7msccbos6639a5gm.apps.googleusercontent.com
NEXT_PUBLIC_LIVEKIT_URL=ws://10.184.70.68:7880
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
